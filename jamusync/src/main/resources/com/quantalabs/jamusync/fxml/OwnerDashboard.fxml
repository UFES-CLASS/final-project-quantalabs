<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a VBox: a full width deep brown header on top, then
     the sidebar navigation and the main content side by side below. -->
<VBox styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.OwnerDashboardController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <children>

        <!-- FULL WIDTH deep brown header with the big JamuSync logo -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="header-bar">
            <padding>
                <Insets bottom="10.0" left="30.0" right="30.0" top="10.0" />
            </padding>
            <children>
                <VBox spacing="4.0">
                    <children>
                        <ImageView fitHeight="60.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/jamusync-logo-white.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="header-bar-subtitle" text="OWNER ADMINISTRATION PANEL" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <!-- Signed in user shown on the right of the header -->
                <VBox alignment="CENTER_RIGHT">
                    <children>
                        <Label fx:id="profileLabel" styleClass="top-bar-username" text="admin" />
                        <Label styleClass="top-bar-role" text="Owner" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- Body: sidebar navigation on the left, dashboard content on the right -->
        <HBox VBox.vgrow="ALWAYS">
            <children>

                <!-- Sidebar with the navigation buttons -->
                <VBox maxWidth="260.0" minWidth="260.0" prefWidth="260.0" styleClass="sidebar">
                    <children>
                        <VBox spacing="6.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-btn, sidebar-btn-active" text="Dashboard" />
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavProducts" styleClass="sidebar-btn" text="Products" />
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavStaff" styleClass="sidebar-btn" text="Staff" />
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavInventory" styleClass="sidebar-btn" text="Inventory" />
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavSales" styleClass="sidebar-btn" text="Sales POS" />
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavTransactions" styleClass="sidebar-btn" text="History" />
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavVouchers" styleClass="sidebar-btn" text="Vouchers" />
                                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavReports" styleClass="sidebar-btn" text="Reports" />
                            </children>
                        </VBox>
                        <Region VBox.vgrow="ALWAYS" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-btn" text="Sign Out" />
                    </children>
                </VBox>

                <!-- Scrollable dashboard content -->
                <ScrollPane fitToWidth="true" styleClass="scroll-pane" HBox.hgrow="ALWAYS">
                    <content>
                        <VBox spacing="20.0">
                            <padding>
                                <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
                            </padding>
                            <children>

                                <!-- Row of summary metric cards -->
                                <HBox spacing="20.0">
                                    <children>
                                        <!-- Metric Card 1: revenue -->
                                        <VBox spacing="6.0" styleClass="card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="metric-label" text="Today's Revenue" />
                                                <Label fx:id="revenueLabel" styleClass="metric-value" text="Rp 0" />
                                                <Label fx:id="salesCountLabel" styleClass="metric-accent" text="0 completed sales" />
                                            </children>
                                        </VBox>

                                        <!-- Metric Card 2: low stock -->
                                        <VBox spacing="6.0" styleClass="card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="metric-label" text="Low Stock Alerts" />
                                                <Label fx:id="lowStockAlertLabel" styleClass="metric-warning" text="0 items" />
                                                <Label styleClass="metric-accent" text="Requires restocking soon" />
                                            </children>
                                        </VBox>

                                        <!-- Metric Card 3: pending orders -->
                                        <VBox spacing="6.0" styleClass="card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="metric-label" text="Pending Orders" />
                                                <Label fx:id="pendingOrdersLabel" styleClass="metric-positive" text="0 orders" />
                                                <Label styleClass="metric-accent" text="Awaiting confirmation" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Low stock table and recent transactions table -->
                                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                                    <children>

                                        <!-- Low Stock table -->
                                        <VBox minWidth="280.0" spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                                            <padding>
                                                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="card-title" text="Low Stock Items" />
                                                <TableView fx:id="lowStockTable" maxWidth="1.7976931348623157E308" styleClass="table-view" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="colProductName" minWidth="110.0" prefWidth="130.0" text="Product Name" />
                                                        <TableColumn fx:id="colCurrentStock" minWidth="60.0" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Stock" />
                                                        <TableColumn fx:id="colThreshold" minWidth="85.0" prefWidth="95.0" style="-fx-alignment: CENTER;" text="Threshold" />
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                    </columnResizePolicy>
                                                </TableView>
                                            </children>
                                        </VBox>

                                        <!-- Recent Transactions table -->
                                        <VBox spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                                            <padding>
                                                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="card-title" text="Recent Transactions" />
                                                <TableView fx:id="transactionsTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="colTxId" prefWidth="50.0" style="-fx-alignment: CENTER;" text="ID" />
                                                        <TableColumn fx:id="colTxBuyer" prefWidth="120.0" text="Buyer" />
                                                        <TableColumn fx:id="colTxType" prefWidth="80.0" style="-fx-alignment: CENTER;" text="Type" />
                                                        <TableColumn fx:id="colTxTotal" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT;" text="Total" />
                                                        <TableColumn fx:id="colTxStatus" prefWidth="90.0" style="-fx-alignment: CENTER;" text="Status" />
                                                        <TableColumn fx:id="colTxDate" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Recorded" />
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                    </columnResizePolicy>
                                                </TableView>
                                            </children>
                                        </VBox>

                                        <!-- Today's sales breakdown pie chart, next to the tables -->
                                        <VBox minWidth="260.0" spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                                            <padding>
                                                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                                            </padding>
                                            <children>
                                                <Label styleClass="card-title" text="Today's Sales Breakdown" />
                                                <PieChart fx:id="dashPieChart" legendSide="BOTTOM" title="Today's Sales Breakdown" VBox.vgrow="ALWAYS" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </HBox>
    </children>
</VBox>
