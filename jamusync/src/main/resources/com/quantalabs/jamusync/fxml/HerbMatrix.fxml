<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a VBox: a light guest nav bar on top, then the scrollable
     herb grid below. This is a guest screen (no login needed). -->
<VBox styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.HerbMatrixController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <children>

        <!-- GUEST NAV BAR: logo on the left, nav pills in the center, back button on the right -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="guest-nav-bar">
            <children>

                <!-- Logo. The bar is light cream, so we use dark brown text here. -->
                <!-- JamuSync logo and QuantaLabs logo side by side -->
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <ImageView fitHeight="110.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/JamuSync_logofinal.png" />
                            </image>
                        </ImageView>
                        <ImageView fitHeight="70.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/quantalabs-logo.png" />
                            </image>
                        </ImageView>
                    </children>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- The three navigation pills in the middle -->
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <!-- We are on this screen, so this pill is active -->
                        <Button mnemonicParsing="false" styleClass="nav-pill, nav-pill-active" text="Herb Matrix" />
                        <Button mnemonicParsing="false" onAction="#handleNavMixer" styleClass="nav-pill" text="Jamu Mixer" />
                        <Button mnemonicParsing="false" onAction="#handleNavSymptom" styleClass="nav-pill" text="Symptom Sync" />
                    </children>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Cart button (shows how many items are in the cart) -->
                <Button fx:id="cartButton" mnemonicParsing="false" onAction="#handleNavCart" styleClass="nav-pill" text="Cart (0)" />

                <!-- Back to login button on the right -->
                <Button mnemonicParsing="false" onAction="#handleBackToLogin" styleClass="button-outline" text="Back to Login" />
            </children>
        </HBox>

        <!-- The scrollable content: a title section and then the herb grid -->
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
            <content>
                <!-- Center the content and cap it at 1200px on very wide screens -->
                <VBox alignment="TOP_CENTER">
                    <children>
                        <VBox maxWidth="1200.0">
                            <children>

                                <!-- Title section -->
                                <VBox spacing="6.0" styleClass="guest-title-section">
                                    <children>
                                        <Label styleClass="guest-eyebrow" text="MATERIA MEDICA" />
                                        <Label styleClass="guest-title" text="The Herb Matrix" />
                                        <Label styleClass="label-muted" text="Explore the traditional herbs behind every cup of jamu - their origins, batik patterns, flavors, and wellness benefits." wrapText="true" />
                                    </children>
                                </VBox>

                                <!-- The grid of herb cards. The controller fills this in code. -->
                                <FlowPane fx:id="herbGrid" hgap="20.0" vgap="20.0">
                                    <padding>
                                        <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
                                    </padding>
                                </FlowPane>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
