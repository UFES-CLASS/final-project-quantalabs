<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a VBox: full width deep brown header on top, then the sidebar
     navigation and the main content side by side below. Same look as the
     owner dashboard, but the sidebar only shows staff features. -->
<VBox styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.StaffDashboardController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <children>

        <!-- FULL WIDTH deep brown header with the big JamuSync logo -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="header-bar">
            <children>
                <VBox spacing="14.0">
                    <children>
                        <ImageView fitHeight="100.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/jamusync-logo-white.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="header-bar-subtitle" text="STAFF OPERATION PANEL" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT">
                    <children>
                        <Label fx:id="profileLabel" styleClass="top-bar-username" text="Staff Name" />
                        <Label styleClass="top-bar-role" text="Staff" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- Body: staff sidebar on the left, dashboard content on the right -->
        <HBox VBox.vgrow="ALWAYS">
            <children>

                <!-- Sidebar with only the staff navigation buttons -->
                <VBox maxWidth="260.0" minWidth="260.0" prefWidth="260.0" styleClass="sidebar">
                    <children>
                        <VBox spacing="6.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Button fx:id="navDashboardBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="sidebar-btn, sidebar-btn-active" text="Dashboard" />
                                <Button fx:id="navSalesBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavSales" styleClass="sidebar-btn" text="Sales POS" />
                                <Button fx:id="navInventoryBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavInventory" styleClass="sidebar-btn" text="Inventory" />
                            </children>
                        </VBox>
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="signOutBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-btn" text="Sign Out" />
                    </children>
                </VBox>

                <!-- Scrollable dashboard content -->
                <ScrollPane fitToWidth="true" styleClass="scroll-pane" HBox.hgrow="ALWAYS">
                    <content>
                        <VBox spacing="24.0">
                            <padding>
                                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                            </padding>
                            <children>

                                <!-- Row of two summary metric cards -->
                                <HBox spacing="20.0">
                                    <children>
                                        <!-- Metric Card 1: today's revenue -->
                                        <VBox spacing="6.0" styleClass="card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="revenueTitleLabel" styleClass="metric-label" text="Your Sales Revenue (Today)" />
                                                <Label fx:id="revenueLabel" styleClass="metric-value" text="Rp 0" />
                                                <Label styleClass="metric-accent" text="Completed orders recorded by you today" />
                                            </children>
                                        </VBox>

                                        <!-- Metric Card 2: today's transaction count -->
                                        <VBox spacing="6.0" styleClass="card" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="metric-label" text="Your Transactions Count (Today)" />
                                                <Label fx:id="salesCountLabel" styleClass="metric-positive" text="0 orders" />
                                                <Label styleClass="metric-accent" text="Transactions processed by you today" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Recent transactions table -->
                                <VBox spacing="10.0" styleClass="card" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="card-title" text="Your Recent Transactions" />
                                        <TableView fx:id="transactionsTable" prefHeight="300.0" styleClass="table-view">
                                            <columns>
                                                <TableColumn fx:id="colTxId" prefWidth="60.0" style="-fx-alignment: CENTER;" text="ID" />
                                                <TableColumn fx:id="colTxBuyer" prefWidth="150.0" text="Buyer" />
                                                <TableColumn fx:id="colTxType" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Type" />
                                                <TableColumn fx:id="colTxTotal" prefWidth="120.0" style="-fx-alignment: CENTER-RIGHT;" text="Total" />
                                                <TableColumn fx:id="colTxStatus" prefWidth="110.0" style="-fx-alignment: CENTER;" text="Status" />
                                                <TableColumn fx:id="colTxDate" prefWidth="150.0" style="-fx-alignment: CENTER;" text="Recorded At" />
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </HBox>
    </children>
</VBox>
