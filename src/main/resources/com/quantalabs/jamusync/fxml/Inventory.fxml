<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a VBox: full width header on top, then the movement table and
     the stock operation form below. -->
<VBox styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.InventoryController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <children>

        <!-- FULL WIDTH deep brown header -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="header-bar">
            <children>
                <VBox>
                    <children>
                        <ImageView fitHeight="80.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/jamusync-logo-white.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="header-bar-subtitle" text="INVENTORY - RESTOCK, ADJUST, AND TRACK STOCK MOVEMENTS" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleBack" styleClass="button-header-outline" text="Back to Dashboard" />
            </children>
        </HBox>

        <!-- Body: stock movement table on the left, stock operation form on the right -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>

                <!-- LEFT: the stock movement history table -->
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="card-title" text="Stock Movement History" />
                        <TableView fx:id="movementTable" maxWidth="1.7976931348623157E308" styleClass="table-view" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colDate" minWidth="110.0" prefWidth="130.0" text="Date" />
                                <TableColumn fx:id="colProduct" minWidth="120.0" prefWidth="150.0" text="Product" />
                                <TableColumn fx:id="colType" minWidth="70.0" prefWidth="90.0" style="-fx-alignment: CENTER;" text="Type" />
                                <TableColumn fx:id="colQty" minWidth="55.0" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Qty" />
                                <TableColumn fx:id="colUser" minWidth="80.0" prefWidth="100.0" text="By" />
                                <TableColumn fx:id="colNote" minWidth="110.0" prefWidth="150.0" text="Note" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <!-- RIGHT: the stock operation form -->
                <VBox maxWidth="380.0" minWidth="380.0" prefWidth="380.0" styleClass="card" HBox.hgrow="NEVER">
                    <children>
                        <Label styleClass="card-title" text="Stock Operation">
                            <VBox.margin>
                                <Insets bottom="15.0" />
                            </VBox.margin>
                        </Label>
                        <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox spacing="12.0">
                                    <children>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label styleClass="label-form" text="Product *" />
                                                <ComboBox fx:id="productCombo" maxWidth="1.7976931348623157E308" promptText="Select product..." />
                                            </children>
                                        </VBox>
                                        <Label fx:id="currentStockLabel" styleClass="metric-value" text="Current Stock: -" />
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label styleClass="label-form" text="Operation Type *" />
                                                <ComboBox fx:id="typeCombo" maxWidth="1.7976931348623157E308" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label fx:id="quantityLabel" styleClass="label-form" text="Quantity *" />
                                                <TextField fx:id="quantityField" promptText="Enter quantity..." />
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label styleClass="label-form" text="Note" />
                                                <TextArea fx:id="noteField" prefHeight="60.0" promptText="Optional note..." wrapText="true" />
                                            </children>
                                        </VBox>
                                        <Label fx:id="messageLabel" styleClass="label-success" wrapText="true" />
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                        <Button fx:id="submitButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSubmit" text="Submit Stock Change">
                            <VBox.margin>
                                <Insets top="15.0" />
                            </VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
