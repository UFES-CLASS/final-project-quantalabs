<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a VBox: full width header on top, then the POS content below. -->
<VBox styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.SalesController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <children>

        <!-- FULL WIDTH deep brown header -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="header-bar">
            <children>
                <VBox>
                    <children>
                        <ImageView fitHeight="80.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/jamusync-logo-white.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="header-bar-subtitle" text="SALES POS - RECORD WALK-IN AND WHATSAPP ORDERS" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleBack" styleClass="button-header-outline" text="Back to Dashboard" />
            </children>
        </HBox>

        <!-- POS body: order entry and cart on the left, checkout summary on the right -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>

                <!-- LEFT: choose products and build the cart -->
                <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>

                        <!-- Order type and buyer name -->
                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="label-form" text="Order Type" />
                                        <ComboBox fx:id="orderTypeCombo" maxWidth="1.7976931348623157E308" />
                                    </children>
                                </VBox>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="label-form" text="Buyer Name" />
                                        <TextField fx:id="buyerNameField" promptText="Optional buyer name..." />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- Product picker: choose a product, enter a quantity, add it -->
                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="label-form" text="Add Product to Cart" />
                                <HBox spacing="10.0">
                                    <children>
                                        <ComboBox fx:id="productCombo" prefWidth="250.0" promptText="Select product..." HBox.hgrow="ALWAYS" />
                                        <TextField fx:id="quantityField" prefWidth="80.0" promptText="Qty" />
                                        <Button mnemonicParsing="false" onAction="#handleAddToCart" styleClass="button-secondary" text="Add to Cart" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- The cart table grows to fill the space -->
                        <TableView fx:id="cartTable" maxWidth="1.7976931348623157E308" styleClass="table-view" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colProduct" minWidth="150.0" prefWidth="220.0" text="Product" />
                                <TableColumn fx:id="colUnitPrice" minWidth="90.0" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT;" text="Unit Price" />
                                <TableColumn fx:id="colQty" minWidth="55.0" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Qty" />
                                <TableColumn fx:id="colSubtotal" minWidth="95.0" prefWidth="110.0" style="-fx-alignment: CENTER-RIGHT;" text="Subtotal" />
                                <TableColumn fx:id="colAction" minWidth="70.0" prefWidth="80.0" style="-fx-alignment: CENTER;" text="Action" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <!-- RIGHT: order summary and checkout -->
                <VBox maxWidth="380.0" minWidth="380.0" prefWidth="380.0" spacing="15.0" styleClass="card" HBox.hgrow="NEVER">
                    <children>
                        <Label styleClass="card-title" text="Order Summary" />

                        <!-- Voucher code, placed near the top so it is easy to find -->
                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="label-form" text="Voucher Code" />
                                <HBox spacing="8.0">
                                    <children>
                                        <TextField fx:id="voucherCodeField" promptText="Enter voucher code..." HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" onAction="#handleApplyVoucher" styleClass="button-outline" text="Apply" />
                                    </children>
                                </HBox>
                                <Label fx:id="voucherInfoLabel" styleClass="label-muted" text="" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- Thin divider before the money totals -->
                        <Region maxWidth="1.7976931348623157E308" styleClass="divider" />

                        <!-- Totals -->
                        <Label fx:id="subtotalLabel" styleClass="text-dark" text="Subtotal: Rp 0" />
                        <Label fx:id="discountLabel" styleClass="text-accent" text="Discount: Rp 0" />
                        <Label fx:id="totalLabel" styleClass="metric-value" text="Total: Rp 0" />

                        <Region VBox.vgrow="ALWAYS" />

                        <!-- Checkout buttons -->
                        <Button fx:id="completeButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleCompleteSale" text="Complete Sale" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleClearCart" styleClass="button-outline" text="Clear Cart" />
                        <Label fx:id="messageLabel" styleClass="label-success" wrapText="true" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
