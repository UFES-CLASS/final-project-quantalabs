<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a VBox: a full width header on top, then the main content below. -->
<VBox styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.CatalogController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <children>

        <!-- FULL WIDTH deep brown header bar (the market signboard) -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="header-bar">
            <children>
                <!-- Large JamuSync logo text (45px) -->
                <VBox>
                    <children>
                        <ImageView fitHeight="45.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/jamusync-logo-white.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="header-bar-subtitle" text="EXPLORE TRADITIONAL INDONESIAN HERBAL DRINKS" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="searchField" prefWidth="220.0" promptText="Search products..." />
                <ComboBox fx:id="filterCombo" prefWidth="160.0" promptText="Filter by benefit..." />
                <Button mnemonicParsing="false" onAction="#handleBackToLogin" styleClass="button-header-outline" text="Back to Login" />
            </children>
        </HBox>

        <!-- Main content area: products on the left, assistant panel on the right -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>

                <!-- LEFT: product cards in a FlowPane that fills all the space -->
                <ScrollPane fitToWidth="true" styleClass="scroll-pane" HBox.hgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="productGrid" hgap="15.0" vgap="15.0">
                            <padding>
                                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                            </padding>
                        </FlowPane>
                    </content>
                </ScrollPane>

                <!-- RIGHT: fixed 320px column that is ALWAYS visible.
                     It holds the product details and the Jamu Assistant chatbot. -->
                <VBox maxWidth="320.0" minWidth="320.0" prefWidth="320.0" spacing="12.0" styleClass="card" HBox.hgrow="NEVER">
                    <children>

                        <!-- Product details section -->
                        <Label styleClass="card-title" text="Product Details" />
                        <HBox alignment="CENTER" prefHeight="120.0" styleClass="image-preview-box">
                            <children>
                                <ImageView fx:id="detailImageView" fitHeight="110.0" fitWidth="140.0" pickOnBounds="true" preserveRatio="true" />
                            </children>
                        </HBox>
                        <Label fx:id="detailNameLabel" styleClass="detail-name" text="Select a product" wrapText="true" />
                        <Label fx:id="detailPriceLabel" styleClass="detail-price" />
                        <Label fx:id="detailDescriptionLabel" wrapText="true" />
                        <Label styleClass="label-form" text="Ingredients" />
                        <Label fx:id="detailIngredientsLabel" wrapText="true" />
                        <Label styleClass="label-form" text="Health Benefits" />
                        <Label fx:id="detailBenefitsLabel" wrapText="true" />

                        <!-- Thin divider between details and the chatbot -->
                        <Region maxWidth="1.7976931348623157E308" styleClass="divider">
                            <VBox.margin>
                                <Insets bottom="4.0" top="8.0" />
                            </VBox.margin>
                        </Region>

                        <!-- Jamu Assistant chatbot section (always shown here) -->
                        <Label styleClass="card-title" text="Jamu Assistant" />
                        <TextArea fx:id="chatHistoryArea" editable="false" prefHeight="130.0" promptText="Ask about jamu health benefits..." wrapText="true" VBox.vgrow="ALWAYS" />
                        <HBox spacing="8.0">
                            <children>
                                <TextField fx:id="chatInputField" promptText="Type your question..." HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleSendChat" styleClass="button-secondary" text="Ask" />
                            </children>
                        </HBox>
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGetRecommendations" text="Get Recommendations" />
                        <Label fx:id="recommendationLabel" wrapText="true" />
                    </children>
                </VBox>

            </children>
        </HBox>
    </children>
</VBox>
