<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a VBox: full width header on top, then the table and form below. -->
<VBox styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.VoucherController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <children>

        <!-- FULL WIDTH deep brown header -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="header-bar">
            <children>
                <VBox>
                    <children>
                        <ImageView fitHeight="80.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/jamusync-logo-white.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="header-bar-subtitle" text="VOUCHER MANAGEMENT - CREATE AND MANAGE DISCOUNT VOUCHERS" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleBack" styleClass="button-header-outline" text="Back to Dashboard" />
            </children>
        </HBox>

        <!-- Body: voucher table on the left, voucher form on the right -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>

                <!-- LEFT: the voucher table -->
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="card-title" text="All Vouchers" />
                        <TableView fx:id="voucherTable" maxWidth="1.7976931348623157E308" styleClass="table-view" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colCode" minWidth="100.0" prefWidth="120.0" text="Code" />
                                <TableColumn fx:id="colType" minWidth="75.0" prefWidth="90.0" style="-fx-alignment: CENTER;" text="Type" />
                                <TableColumn fx:id="colValue" minWidth="75.0" prefWidth="90.0" style="-fx-alignment: CENTER-RIGHT;" text="Value" />
                                <TableColumn fx:id="colUsage" minWidth="80.0" prefWidth="80.0" style="-fx-alignment: CENTER;" text="Used/Limit" />
                                <TableColumn fx:id="colExpiry" minWidth="90.0" prefWidth="110.0" text="Expiry" />
                                <TableColumn fx:id="colActive" minWidth="60.0" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Active" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <!-- RIGHT: the voucher form -->
                <VBox maxWidth="380.0" minWidth="380.0" prefWidth="380.0" styleClass="card" HBox.hgrow="NEVER">
                    <children>
                        <Label styleClass="card-title" text="Voucher Form">
                            <VBox.margin>
                                <Insets bottom="15.0" />
                            </VBox.margin>
                        </Label>
                        <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="label-form" text="Voucher Code *" />
                                        <TextField fx:id="codeField" promptText="e.g. JAMU10" />
                                    </children>
                                </VBox>
                                <HBox spacing="15.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="label-form" text="Discount Type *" />
                                                <ComboBox fx:id="typeCombo" maxWidth="1.7976931348623157E308" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="label-form" text="Discount Value *" />
                                                <TextField fx:id="valueField" promptText="e.g. 10 or 5000" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox spacing="15.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="label-form" text="Usage Limit *" />
                                                <TextField fx:id="usageLimitField" promptText="e.g. 100" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="label-form" text="Expiry Date *" />
                                                <DatePicker fx:id="expiryPicker" maxWidth="1.7976931348623157E308" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <CheckBox fx:id="activeCheckbox" mnemonicParsing="false" selected="true" styleClass="label-form" text="Voucher is Active" />
                                <Label fx:id="messageLabel" styleClass="label-success" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- Action buttons at the bottom of the form -->
                        <VBox spacing="8.0">
                            <padding>
                                <Insets top="15.0" />
                            </padding>
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="saveButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSave" text="Save Voucher" HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" onAction="#handleClear" styleClass="button-outline" text="Clear" />
                                    </children>
                                </HBox>
                                <Button fx:id="deactivateButton" disable="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDeactivate" styleClass="button-danger" text="Deactivate Voucher" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
