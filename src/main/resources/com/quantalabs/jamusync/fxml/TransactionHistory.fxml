<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a VBox: full width header on top, then a filter bar, the table,
     and the action buttons below. -->
<VBox styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.TransactionHistoryController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <children>

        <!-- FULL WIDTH deep brown header -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="header-bar">
            <children>
                <VBox>
                    <children>
                        <ImageView fitHeight="80.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/jamusync-logo-white.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="header-bar-subtitle" text="TRANSACTION HISTORY - VIEW AND MANAGE ALL SALES" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleBack" styleClass="button-header-outline" text="Back to Dashboard" />
            </children>
        </HBox>

        <!-- Content area below the header -->
        <VBox spacing="15.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>

                <!-- Filter bar sits inside a card so it looks like one clean panel -->
                <HBox alignment="BOTTOM_LEFT" spacing="15.0" styleClass="card">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="label-form" text="Status" />
                                <ComboBox fx:id="statusFilter" prefWidth="140.0" />
                            </children>
                        </VBox>
                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="label-form" text="From Date" />
                                <DatePicker fx:id="startDatePicker" />
                            </children>
                        </VBox>
                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="label-form" text="To Date" />
                                <DatePicker fx:id="endDatePicker" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleFilter" styleClass="button-secondary" text="Apply Filter" />
                        <Button mnemonicParsing="false" onAction="#handleClearFilter" styleClass="button-outline" text="Clear" />
                    </children>
                </HBox>

                <!-- The transactions table.
                     Note: the Status column shows the text (Completed / Cancelled / Pending). -->
                <TableView fx:id="transactionTable" maxWidth="1.7976931348623157E308" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" minWidth="45.0" prefWidth="50.0" style="-fx-alignment: CENTER;" text="ID" />
                        <TableColumn fx:id="colBuyer" minWidth="110.0" prefWidth="130.0" text="Buyer" />
                        <TableColumn fx:id="colType" minWidth="75.0" prefWidth="90.0" style="-fx-alignment: CENTER;" text="Type" />
                        <TableColumn fx:id="colSubtotal" minWidth="85.0" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT;" text="Subtotal" />
                        <TableColumn fx:id="colDiscount" minWidth="80.0" prefWidth="90.0" style="-fx-alignment: CENTER-RIGHT;" text="Discount" />
                        <TableColumn fx:id="colTotal" minWidth="85.0" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT;" text="Total" />
                        <TableColumn fx:id="colStatus" minWidth="85.0" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Status" />
                        <TableColumn fx:id="colStaff" minWidth="90.0" prefWidth="100.0" text="Recorded By" />
                        <TableColumn fx:id="colDate" minWidth="110.0" prefWidth="130.0" text="Date" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <!-- Action buttons for the selected transaction -->
                <HBox spacing="10.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#handleViewDetails" text="View Details" />
                        <Button mnemonicParsing="false" onAction="#handleMarkCompleted" styleClass="button-secondary" text="Mark Completed" />
                        <Button mnemonicParsing="false" onAction="#handleMarkCancelled" styleClass="button-danger" text="Mark Cancelled" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
