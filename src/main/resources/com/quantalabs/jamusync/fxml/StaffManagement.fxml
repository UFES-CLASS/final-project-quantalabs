<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Root is a VBox: full width header on top, then the table and form below. -->
<VBox styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quantalabs.jamusync.controller.StaffManagementController">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    <children>

        <!-- FULL WIDTH deep brown header -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="header-bar">
            <children>
                <VBox>
                    <children>
                        <ImageView fitHeight="80.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/jamusync-logo-white.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="header-bar-subtitle" text="STAFF MANAGEMENT - ADD, EDIT, OR DEACTIVATE STAFF ACCOUNTS" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleBack" styleClass="button-header-outline" text="Back to Dashboard" />
            </children>
        </HBox>

        <!-- Body: staff table on the left, staff account form on the right -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>

                <!-- LEFT: the staff table -->
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="card-title" text="All Staff Accounts" />
                        <TableView fx:id="staffTable" maxWidth="1.7976931348623157E308" styleClass="table-view" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" minWidth="45.0" prefWidth="50.0" style="-fx-alignment: CENTER;" text="ID" />
                                <TableColumn fx:id="colUsername" minWidth="150.0" prefWidth="200.0" text="Username" />
                                <TableColumn fx:id="colActive" minWidth="80.0" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Active" />
                                <TableColumn fx:id="colCreated" minWidth="140.0" prefWidth="180.0" text="Created At" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <!-- RIGHT: the staff account form -->
                <VBox maxWidth="380.0" minWidth="380.0" prefWidth="380.0" styleClass="card" HBox.hgrow="NEVER">
                    <children>
                        <Label styleClass="card-title" text="Staff Account Form">
                            <VBox.margin>
                                <Insets bottom="15.0" />
                            </VBox.margin>
                        </Label>
                        <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="label-form" text="Username *" />
                                        <TextField fx:id="usernameField" promptText="Enter staff username..." />
                                    </children>
                                </VBox>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="label-form" text="Password *" />
                                        <PasswordField fx:id="passwordField" promptText="Enter password (required for new staff)..." />
                                    </children>
                                </VBox>
                                <CheckBox fx:id="activeCheckbox" mnemonicParsing="false" selected="true" styleClass="label-form" text="Account is Active" />
                                <Label fx:id="messageLabel" styleClass="label-success" wrapText="true" />
                            </children>
                        </VBox>

                        <!-- Action buttons at the bottom of the form -->
                        <VBox spacing="8.0">
                            <padding>
                                <Insets top="15.0" />
                            </padding>
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="saveButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSave" text="Save Staff" HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" onAction="#handleClear" styleClass="button-outline" text="Clear" />
                                    </children>
                                </HBox>
                                <Button fx:id="deactivateButton" disable="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleDeactivate" styleClass="button-danger" text="Deactivate Staff" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
